   "source": [
    "c_lst = []\n",
    "y_lst = [1, 2, 3, 4, 5]\n",
    "mpc_lst = [0.6, 0.5, 0.5, 0.3, 0.2]\n",
    "\n",
    "for y, mpc in zip(y_lst, mpc_lst):\n",
    "    c = 0.1 + mpc * y\n",
    "    c_lst.append(c)\n",
    "\n",
    "print(c_lst)"
   ]
